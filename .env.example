# LitterBox Frontend Environment Variables
# Copy this file to .env.local and fill in your values

# Solana RPC URL (Devnet for testing)
NEXT_PUBLIC_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_API_KEY

# Program ID (Devnet)
NEXT_PUBLIC_PROGRAM_ID=3X1zzNCdQUhuQDxqVCpyiGoJNcqYVMxEDW3YQBfoVcMe

# Network (devnet or mainnet-beta)
NEXT_PUBLIC_NETWORK=devnet

# Optional: Sentry for error tracking
# NEXT_PUBLIC_SENTRY_DSN=your-sentry-dsn

# Optional: Analytics
# NEXT_PUBLIC_GA_ID=your-google-analytics-id
